{
    "name": "spark-template",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": ">=20.19.0 <21.0.0 || >=22.12.0"
    },
    "scripts": {
        "dev": "vite",
        "kill": "fuser -k 5000/tcp",
        "build": "tsc -b --noCheck && vite build",
        "lint": "eslint .",
        "optimize": "vite optimize",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:visual": "percy exec -- playwright test e2e/visual",
        "test:visual:update": "percy exec -- playwright test e2e/visual --update-snapshots",
        "test:visual:dark": "percy exec -- playwright test e2e/visual/dark-mode-themes.spec.ts",
        "test:visual:themes": "percy exec -- playwright test e2e/visual/theme-comparison.spec.ts",
        "test:visual:local": "playwright test e2e/visual --headed",
        "test:all": "npm run test:run && npm run test:e2e"
    },
    "dependencies": {
        "@github/spark": ">=0.43.1 <1",
        "@heroicons/react": "^2.2.0",
        "@hookform/resolvers": "^5.2.2",
        "@octokit/core": "^7.0.6",
        "@phosphor-icons/react": "^2.1.7",
        "@radix-ui/colors": "^3.0.0",
        "@radix-ui/react-accordion": "^1.2.3",
        "@radix-ui/react-alert-dialog": "^1.1.6",
        "@radix-ui/react-aspect-ratio": "^1.1.2",
        "@radix-ui/react-avatar": "^1.1.3",
        "@radix-ui/react-checkbox": "^1.1.4",
        "@radix-ui/react-collapsible": "^1.1.3",
        "@radix-ui/react-context-menu": "^2.2.6",
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-dropdown-menu": "^2.1.6",
        "@radix-ui/react-hover-card": "^1.1.6",
        "@radix-ui/react-label": "^2.1.2",
        "@radix-ui/react-menubar": "^1.1.6",
        "@radix-ui/react-navigation-menu": "^1.2.5",
        "@radix-ui/react-popover": "^1.1.6",
        "@radix-ui/react-progress": "^1.1.2",
        "@radix-ui/react-radio-group": "^1.2.3",
        "@radix-ui/react-scroll-area": "^1.2.9",
        "@radix-ui/react-select": "^2.1.6",
        "@radix-ui/react-separator": "^1.1.2",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.2",
        "@radix-ui/react-switch": "^1.1.3",
        "@radix-ui/react-tabs": "^1.1.3",
        "@radix-ui/react-toggle": "^1.1.2",
        "@radix-ui/react-toggle-group": "^1.1.2",
        "@radix-ui/react-tooltip": "^1.1.8",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-query": "^5.95.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "d3": "^7.9.0",
        "date-fns": "^4.1.0",
        "embla-carousel-react": "^8.5.2",
        "framer-motion": "^12.38.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.577.0",
        "marked": "^17.0.5",
        "next-themes": "^0.4.6",
        "octokit": "^5.0.5",
        "react": "^19.0.0",
        "react-day-picker": "^9.14.0",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.1",
        "react-hook-form": "^7.72.0",
        "react-resizable-panels": "^4.7.5",
        "recharts": "^3.8.0",
        "sonner": "^2.0.1",
        "tailwind-merge": "^3.5.0",
        "three": "^0.183.2",
        "tw-animate-css": "^1.2.4",
        "uuid": "^13.0.0",
        "vaul": "^1.1.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@percy/cli": "^1.31.10",
        "@percy/playwright": "^1.0.10",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "happy-dom": "^20.8.4",
        "tailwindcss": "^4.2.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    },
    "workspaces": {
        "packages": [
            "packages/*"
        ]
    }
}
